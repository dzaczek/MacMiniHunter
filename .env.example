# PostgreSQL
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mac_tracker
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tracker:change_me_in_production@db:5432/mac_tracker

# Matrix (Element) notifications
# Get your access token: Element > Settings > Help & About > Access Token
# Room ID: Room Settings > Advanced > Internal room ID (e.g. !abc123:matrix.org)
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=your_access_token_here
MATRIX_ROOM_ID=!your_room_id:matrix.org

# Scraper settings
SCRAPE_INTERVAL_HOURS=6
REQUEST_DELAY_MIN=2.5
REQUEST_DELAY_MAX=7.8

# Dashboard authentication (REQUIRED)
DASH_USER=admin
DASH_PASS=change_me_strong_password

# Cloudflare Tunnel (REQUIRED for remote access)
# 1. Go to https://one.dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels
# 2. Create a tunnel, copy the token
# 3. Configure the tunnel public hostname to point to http://dashboard:8080
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
